# ─── Database ────────────────────────────────────────────────────────────────
# Obtain from CloudFormation output: <stack-name>-RDSEndpoint
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com

# Default: sleepquiz
DB_NAME=sleepquiz

DB_USER=sleepquiz_admin

# Must match the DBPassword parameter used during CloudFormation deploy
DB_PASSWORD=

# Default: 5432
DB_PORT=5432

# ─── VPC / Lambda Networking ─────────────────────────────────────────────────
# Obtain from CloudFormation output: <stack-name>-LambdaSGId
VPC_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx

# Obtain from CloudFormation output: <stack-name>-PrivateSubnet1Id
VPC_SUBNET_ID_1=subnet-xxxxxxxxxxxxxxxxx

# Obtain from CloudFormation output: <stack-name>-PrivateSubnet2Id
VPC_SUBNET_ID_2=subnet-xxxxxxxxxxxxxxxxx

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Production: https://sleeptypequiz.com
# Local dev:  http://localhost:5173
ALLOWED_ORIGIN=https://sleeptypequiz.com

# ─── Domain & DNS ─────────────────────────────────────────────────────────────
DOMAIN_NAME=sleeptypequiz.com

# Route53 Hosted Zone ID for sleeptypequiz.com
HOSTED_ZONE_ID=ZXXXXXXXXXXXXXXXXXXXX

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# Deployment stage: prod | staging | dev
STAGE=prod

# ─── CloudFormation Stack ─────────────────────────────────────────────────────
# Name used when deploying cloudformation/infrastructure.yml
CF_STACK_NAME=sleep-type-infra

# ─── Frontend Hosting (populated after CF deploy) ─────────────────────────────
# Obtain from CloudFormation output: <stack-name>-FrontendBucket
S3_BUCKET_NAME=sleep-type-infra-frontend-123456789012

# Obtain from CloudFormation output: <stack-name>-CloudFrontDistributionId
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXX
